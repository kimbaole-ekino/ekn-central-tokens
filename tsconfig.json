{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    ".storybook/**/*.ts",
    "scripts/**/*.ts",
    "storybook/**/*.ts",
    "storybook/**/*.d.mts",
    "tests/**/*.ts"
  ]
}
