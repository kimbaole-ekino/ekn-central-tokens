{
  "primitive": {
    "color": {
      "brand": {
        "primary": {
          "type": "color",
          "value": "#a90000",
          "$extensions": {
            "ekinoTokenArchitect": {
              "id": "tok_project_b_brand_primary"
            }
          }
        }
      }
    },
    "spacing": {
      "md": {
        "type": "spacing",
        "value": "12px",
        "$extensions": {
          "ekinoTokenArchitect": {
            "id": "tok_project_b_spacing_md"
          }
        }
      }
    }
  },
  "semantic-light": {
    "color": {
      "background": {
        "default": {
          "type": "color",
          "value": "#f7f7f5",
          "$extensions": {
            "ekinoTokenArchitect": {
              "id": "tok_project_b_bg_default"
            }
          }
        }
      },
      "text": {
        "primary": {
          "type": "color",
          "value": "#222220",
          "$extensions": {
            "ekinoTokenArchitect": {
              "id": "tok_project_b_text_primary"
            }
          }
        }
      }
    }
  },
  "$themes": [
    {
      "id": "project-b-light",
      "name": "Project B / Light",
      "selectedTokenSets": {
        "primitive": "enabled",
        "semantic-light": "enabled"
      }
    }
  ],
  "$metadata": {
    "tokenSetOrder": ["primitive", "semantic-light"]
  }
}
