{
  "component-button": {
    "color": {
      "background": {
        "primary": {
          "type": "color",
          "value": "{primitive.color.brandprimary}",
          "$extensions": {
            "ekinoTokenArchitect": {
              "id": "tok_project_a_button_bg_primary"
            }
          }
        }
      }
    },
    "spacing": {
      "padding": {
        "x": {
          "type": "spacing",
          "value": "12px",
          "$extensions": {
            "ekinoTokenArchitect": {
              "id": "tok_project_a_button_padding_x"
            }
          }
        }
      }
    }
  },
  "primitive": {
