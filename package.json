{
  "name": "ekn-central-tokens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "tsx --test tests/*.test.ts",
    "validate": "npm test && npm run typecheck && npm run validate:tokens && npm run build:artifacts && npm run delivery:target-mr",
    "validate:tokens": "tsx scripts/validate-token-projects.ts",
    "detect:affected-projects": "tsx scripts/detect-affected-token-projects.ts",
    "build:artifacts": "tsx scripts/build-token-artifacts.ts",
    "delivery:target-mr": "tsx scripts/create-target-merge-requests.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@eknvn/token-validator": "^0.1.0-uat.3",
    "@tokens-studio/sd-transforms": "^1.3.0",
    "@tokens-studio/types": "^0.5.2",
    "@types/node": "^26.1.0",
    "style-dictionary": "^4.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
