{
  "name": "ekn-central-tokens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "validate": "npm run validate:tokens && npm run check:stale-token-pr && npm run build:artifacts && npm run delivery:target-mr",
    "validate:tokens": "tsx scripts/validate-token-projects.ts",
    "detect:affected-projects": "tsx scripts/detect-affected-token-projects.ts",
    "build:style-dictionary": "tsx scripts/build-token-artifacts.ts",
    "build:artifacts": "tsx scripts/build-token-artifacts.ts",
    "check:stale-token-pr": "tsx scripts/check-stale-token-pr.ts",
    "delivery:target-mr": "tsx scripts/create-target-merge-requests.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@tokens-studio/sd-transforms": "^1.3.0",
    "@types/node": "^26.1.0",
    "style-dictionary": "^4.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
